# PostgreSQL (use DB_* — avoids Windows USERNAME conflict)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=1234
DB_NAME=access

# FastAPI server (bind all interfaces; Flutter uses API_PUBLIC_HOST)
API_HOST=0.0.0.0
API_PORT=3001
# Current PC LAN IPv4 (run `ipconfig` and use the IPv4 of the Wi-Fi adapter).
API_PUBLIC_HOST=192.168.137.25

# Host header allowlist (comma-separated) for TrustedHostMiddleware.
# In dev we allow any host to avoid "400 Invalid host header" when switching
# Wi‑Fi networks / IPs (mobile devices frequently hit by IP, hostname, or port).
ALLOWED_HOSTS=*

JWT_SECRET=access_visioncheck_dev_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

CORS_ORIGINS=http://192.168.137.25:3001,http://192.168.137.25,http://192.168.137.162:3001,http://192.168.137.162,http://192.168.0.137:3001,http://192.168.0.137,http://10.0.22.98:3001,http://10.0.22.98,http://localhost:3001,http://127.0.0.1:3001,http://localhost,http://127.0.0.1

# Facebook Page — server-side posting (Graph API)
FACEBOOK_PAGE_ID=61590008614900
FACEBOOK_PAGE_ACCESS_TOKEN=
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=100
