# PostgreSQL (ACCESS VisionCheck)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=1234
DB_NAME=access

# Or single connection URL:
# DATABASE_URL=postgresql+psycopg://postgres:1234@localhost:5432/access

# Development: drop all tables before create (use with care)
# RECREATE_DB=true

# FastAPI — Admin Web (Chrome) + Mobile (Android / LAN)
API_HOST=0.0.0.0
API_PORT=3001
API_PUBLIC_HOST=10.0.22.98

ALLOWED_HOSTS=10.0.22.98,localhost,127.0.0.1

JWT_SECRET=change_this_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

CORS_ORIGINS=http://10.0.22.98:3001,http://localhost:3001,http://127.0.0.1:3001,http://localhost,http://127.0.0.1
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=100

# Facebook Page — Nono gaming (https://www.facebook.com/profile.php?id=61590008614900)
FACEBOOK_PAGE_ID=61590008614900
FACEBOOK_PAGE_ACCESS_TOKEN=

# Meta app (optional — mobile SDK)
FACEBOOK_APP_ID=
FACEBOOK_CLIENT_TOKEN=
