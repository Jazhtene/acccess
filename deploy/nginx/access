# ACCESS VisionCheck API — Nginx reverse proxy (Step 7)
#
# Install on Kamatera (Ubuntu):
#   sudo cp deploy/nginx/access /etc/nginx/sites-available/access
#   sudo ln -sf /etc/nginx/sites-available/access /etc/nginx/sites-enabled/access
#   sudo rm -f /etc/nginx/sites-enabled/default
#   sudo nginx -t && sudo systemctl reload nginx
#
# Requires: FastAPI listening on 127.0.0.1:3001 (access-api systemd service)

server {
    listen 80;
    listen [::]:80;
    server_name 103.125.217.117;

    client_max_body_size 100M;

    # Health + API + uploaded media (FastAPI serves /uploads)
    location / {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }
}
