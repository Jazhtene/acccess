{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "ACCESS — Web Admin (Chrome)",
      "request": "launch",
      "type": "dart",
      "program": "lib/web_admin/main_web.dart",
      "deviceId": "chrome",
      "toolArgs": ["--dart-define-from-file=config/api.json"]
    },
    {
      "name": "ACCESS — Mobile App",
      "request": "launch",
      "type": "dart",
      "program": "lib/mobile_app/main_mobile.dart",
      "toolArgs": ["--dart-define-from-file=config/api.json"]
    }
  ]
}
